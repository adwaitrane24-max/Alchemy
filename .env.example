# ──────────────────────────────────────────────
# Alchemy — Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────

# ── Application ──────────────────────────────
ALCHEMY_ENV=development
ALCHEMY_DEBUG=true
ALCHEMY_LOG_LEVEL=DEBUG

# ── Mozilla Otari Gateway ────────────────────
OTARI_API_KEY=
OTARI_BASE_URL=
OTARI_TIMEOUT_MS=5000

# ── OpenAI (via Otari) ──────────────────────
OPENAI_API_KEY=

# ── Ollama (Local 2B) ───────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma:2b

# ── Smallest.ai (Voice STT) ─────────────────
SMALLEST_AI_API_KEY=
SMALLEST_AI_BASE_URL=

# ── Budget ───────────────────────────────────
BUDGET_DAILY_LIMIT_USD=5.00
BUDGET_WARNING_THRESHOLD=0.60
BUDGET_CRITICAL_THRESHOLD=0.85

# ── Semantic Cache ───────────────────────────
CACHE_SIMILARITY_THRESHOLD=0.85
CACHE_DEFAULT_TTL_HOURS=168
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Database ─────────────────────────────────
DATABASE_PATH=data/alchemy.db

# ── Security ─────────────────────────────────
SECURITY_FAIL_OPEN=false
SECURITY_LOG_BLOCKED=true

# ── Context Manager ─────────────────────────
CONTEXT_MAX_CHUNKS_HEALTHY=5
CONTEXT_MAX_CHUNKS_LOW=3
CONTEXT_SUMMARY_MAX_TOKENS=200
